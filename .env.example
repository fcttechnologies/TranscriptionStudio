# TranscribingApp environment variables.
# Copy to `.env` and uncomment the lines you want to override.
# All values fall back to the defaults in backend/app/config.py.

# Where downloaded audio and intermediate files are stored.
# Defaults to <system-temp>/transcribingapp/.
#TRANSCRIBINGAPP_TEMP_DIR=/tmp/transcribingapp

# Faster-Whisper model name.
# Examples: tiny.en, base.en, small.en, medium.en, large-v3.
#WHISPER_MODEL_NAME=base.en

# Inference device: cpu, cuda, or auto.
#WHISPER_DEVICE=cpu

# Precision/quantization. int8 for low-RAM CPU, float16 for CUDA.
#WHISPER_COMPUTE_TYPE=int8

# Directory containing the ffmpeg binary.
# Leave unset to auto-detect via PATH, /opt/homebrew/bin, /usr/local/bin, /usr/bin.
#FFMPEG_LOCATION=/opt/homebrew/bin

# Standard Python logging level: DEBUG, INFO, WARNING, ERROR.
#LOG_LEVEL=INFO
